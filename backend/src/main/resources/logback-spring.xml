<?xml version="1.0" encoding="UTF-8"?>
<!--
    Logback Configuration for LandIt Backend
    @author Azir

    Features:
    - Console output only (no file logging)
    - Colorized output for better readability
    - Profile-based log level control
-->
<configuration scan="true" scanPeriod="30 seconds">

    <!-- ============================================ -->
    <!-- Properties                                    -->
    <!-- ============================================ -->

    <property name="APP_NAME" value="landit"/>

    <!-- 控制台日志格式（彩色、对齐） -->
    <property name="CONSOLE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %highlight(%-5level) | %-10.10thread | %cyan(%-40.40logger{40}) | %msg%n"/>

    <!-- ============================================ -->
    <!-- Console Appender                              -->
    <!-- ============================================ -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ============================================ -->
    <!-- Logger Configuration                          -->
    <!-- ============================================ -->

    <!-- 项目日志 -->
    <logger name="com.landit" level="DEBUG"/>

    <!-- Spring AI 日志 - 打印请求详情 -->
    <logger name="org.springframework.ai.chat.client.advisor" level="DEBUG"/>

    <!-- Spring Framework -->
    <logger name="org.springframework" level="INFO"/>
    <logger name="org.springframework.web" level="INFO"/>
    <logger name="org.springframework.boot" level="INFO"/>

    <!-- MyBatis-Plus -->
    <logger name="com.baomidou.mybatisplus" level="INFO"/>

    <!-- Hikari 连接池 -->
    <logger name="com.zaxxer.hikari" level="INFO"/>

    <!-- 减少第三方库日志噪音 -->
    <logger name="io.swagger" level="WARN"/>
    <logger name="org.springdoc" level="WARN"/>

    <!-- ============================================ -->
    <!-- Spring Profile Configuration                  -->
    <!-- ============================================ -->

    <!-- 开发环境：DEBUG 级别 -->
    <springProfile name="dev">
        <root level="DEBUG">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- 生产环境：INFO 级别 -->
    <springProfile name="prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <!-- 默认配置 -->
    <springProfile name="!dev &amp; !prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

</configuration>
