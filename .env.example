# =====================================================
# CareerForge 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# @author Azir
# =====================================================

# ==================== AI 服务配置 ====================
# OpenAI API Key（必需）
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API Base URL（可选，默认 https://api.openai.com）
OPENAI_BASE_URL=https://api.openai.com

# AI 模型选择（可选，默认 gpt-4o）
AI_MODEL=gpt-4o

# ==================== 阿里云语音服务 ====================
# 阿里云 Access Key ID（必需，用于语音面试功能）
ALIYUN_ACCESS_KEY_ID=your-aliyun-access-key-id

# 阿里云 Access Key Secret（必需）
ALIYUN_ACCESS_KEY_SECRET=your-aliyun-access-key-secret

# 阿里云语音 App Key（可选）
ALIYUN_VOICE_APP_KEY=your-aliyun-voice-app-key
