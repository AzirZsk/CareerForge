# =====================================================
# CareerForge 环境变量配置示例
# 复制此文件为 .env 并填入真实值
# @author Azir
# =====================================================

# ==================== AI 服务配置 ====================
# OpenAI API Key（必需）
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI API Base URL（可选，默认 https://api.openai.com）
OPENAI_BASE_URL=https://api.openai.com

# AI 模型选择（可选，默认 gpt-4o）
AI_MODEL=gpt-4o

# ==================== JWT 认证 ====================
# JWT 密钥（生产环境必须修改为随机长字符串）
JWT_SECRET=your-jwt-secret-key-at-least-32-chars

# ==================== 阿里云语音服务 ====================
# 阿里云 API Key（用于语音面试功能）
ALIYUN_API_KEY=your-aliyun-api-key-here
